# ClaudeCiberControl - Variables de entorno
# Copiar a .env y ajustar

# Modo de ejecucion: native | docker
CCC_MODE=native

# Directorio de salida para reportes (ruta absoluta recomendada en produccion)
CCC_OUTPUT_DIR=output/reports

# Timeout nmap en segundos (default: 300)
CCC_NMAP_TIMEOUT=300

# HTTP timeout para web scanner en segundos (default: 10)
CCC_HTTP_TIMEOUT=10

# User-Agent para peticiones HTTP
CCC_USER_AGENT=ClaudeCiberControl/1.0 Security Scanner

# Nombre de la organizacion en reportes
CCC_COMPANY_NAME=Mi Empresa - Equipo de Seguridad

# Proxy HTTP (opcional, dejar vacio si no aplica)
# HTTP_PROXY=http://proxy.empresa.com:3128
# HTTPS_PROXY=http://proxy.empresa.com:3128
# NO_PROXY=localhost,127.0.0.1,10.0.0.0/8,192.168.0.0/16
