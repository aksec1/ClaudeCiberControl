SECRET_KEY=cambia-esto-por-una-clave-segura-de-64-caracteres
DATABASE_URL=sqlite:///viaticos.db

# Email (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=tu-correo@empresa.com
MAIL_PASSWORD=tu-contraseña-o-app-password
MAIL_DEFAULT_SENDER=Rendiciones <tu-correo@empresa.com>

# Subida de archivos
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=16777216

# Empresa
COMPANY_NAME=Mi Empresa S.A.
ADMIN_EMAIL=admin@empresa.com

# HTTPS / Proxy
# Poner en 0 solo si se corre sin nginx (directo con run_https.py)
BEHIND_PROXY=1
# Para SSL directo sin nginx (run_https.py):
# SSL_CERT_FILE=ssl/cert.pem
# SSL_KEY_FILE=ssl/key.pem
